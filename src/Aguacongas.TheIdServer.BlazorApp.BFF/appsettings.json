{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ProviderOptions": {
        "Authority": "https://localhost:5443/",
        "ClientId": "theidserveradmin",
        "Scope": [
            "openid",
            "profile",
            "theidserveradminapi"
        ],
        "PostLogoutRedirectUri": "https://localhost:7276/authentication/logout-callback",
        "RedirectUri": "https://localhost:7276/authentication/login-callback",
        "ResponseMode": "query",
        "ResponseType": "code",
        "MapInboundClaims": false,
        "GetClaimsFromUserInfoEndpoint": true,
        "SaveTokens": true,
        "UsePkce": true,
        "TokenValidationParameters": {
            "NameClaimType": "name",
            "RoleClaimType": "role"
        }
    },
    "ApiBaseUrl": "https://localhost:5443"
}
